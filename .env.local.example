# ── Data source: worldcup26.ir ──────────────────────────────────────────
# Free, open, no API key required. No setup needed for FOOTBALL_API_KEY.
#
# Note: top scorers are derived from goal events in match data (accurate
# once matches are played). Squads are not available from this source —
# the squad modal will show "not available" until a squads-capable source
# is added.

# ── Cache settings ─────────────────────────────────────────────────────
# How long (seconds) to cache data
# Live match data: 60s, standings: 300s, team lookup: 86400s (1 day)
CACHE_TTL_LIVE=60
CACHE_TTL_STANDINGS=300
CACHE_TTL_SQUADS=86400

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=WC2026
NEXT_PUBLIC_TIMEZONE=Asia/Bangkok
